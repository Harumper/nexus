generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum Role {
  ADMIN
  OPERATOR
  READONLY
}

enum MachineStatus {
  ENROLLMENT_PENDING
  ONLINE
  OFFLINE
  DEGRADED
  REVOKED
  STALE
  ARCHIVED
}

enum GroupType {
  STATIC
  DYNAMIC
}

enum AuditAction {
  LOGIN
  LOGOUT
  MACHINE_CREATE
  MACHINE_UPDATE
  MACHINE_DELETE
  MACHINE_ENROLL
  MACHINE_REVOKE
  ACTION_REQUEST
  ACTION_COMPLETE
  ACTION_FAILED
  CAPABILITY_GRANT
  CAPABILITY_REVOKE
  CERT_ROTATE
  CERT_REVOKE
  SECURITY_ALERT
  ALERT_TRIGGERED
  ALERT_RESOLVED
  UPDATE_START
  UPDATE_COMPLETE
  UPDATE_FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertConditionType {
  CPU_ABOVE
  MEMORY_ABOVE
  DISK_ABOVE
  MACHINE_OFFLINE
  LOAD_ABOVE
  SERVICE_FAILED
  TIMER_FAILED
  CRON_FAILED
  UPDATES_AVAILABLE
  CERT_EXPIRING
  HARDENING_INDEX_BELOW
  CUSTOM
}

enum AlertStatus {
  FIRING
  RESOLVED
  ACKNOWLEDGED
}

// ===================== USERS =====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(OPERATOR)
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs  AuditLog[]
  alertRules AlertRule[]

  @@index([email])
  @@index([username])
}

// ===================== MACHINES =====================

model Machine {
  id       String        @id @default(cuid())
  name     String
  hostname String?
  os       String?
  osVersion String?
  arch     String?
  ipAddress String?
  agentVersion String?
  status   MachineStatus @default(ENROLLMENT_PENDING)

  // Enrollment
  enrollmentToken  String?   @unique
  enrollmentExpiry DateTime?
  enrolledAt       DateTime?

  // ECDSA - Keys for secure communication
  backendPrivateKey String?  @db.Text  // AES-256-GCM encrypted with ECDSA_MASTER_SECRET
  backendPublicKey  String?  @db.Text  // PEM
  agentPublicKey    String?  @db.Text  // PEM (received at enrollment)
  sharedSecret      String?  @db.Text  // AES-256-GCM encrypted - ECDH derived

  // Security
  boundIp          String?            // IP bound after enrollment
  keyRevokedAt     DateTime?
  keyRevokedReason String?

  // State
  lastHeartbeat DateTime?
  lastMetrics   DateTime?

  // State
  rebootRequired  Boolean     @default(false)
  archivedAt      DateTime?

  // User settings (editable post-enrollment)
  sshUser         String?     // Default username for the SSH button
  isCritical      Boolean     @default(false) // Critical machine: reboot/service_stop/package.remove blocked
  sudoersHash     String?     // SHA256 of the /etc/sudoers.d/nexus-agent file (sent by the agent at heartbeat)
  agentSha256     String?     // SHA256 of the running agent binary (sent at heartbeat) -> fleet-wide "update available" badge

  // Relations
  events       MachineEvent[]
  auditLogs    AuditLog[]
  alertStates  AlertState[]
  tags              MachineTag[]
  groupMembers      MachineGroupMember[]
  bootstrapTokens   BootstrapToken[]
  securityScans     SecurityScan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([name])
  @@index([lastHeartbeat])
  @@index([enrollmentToken])
}

// History of hardening audits (Lynis): one record per scan,
// to track the evolution of the hardening index and detect regressions.
model SecurityScan {
  id      String  @id @default(cuid())
  machineId String
  machine   Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  hardeningIndex  Int     // -1 if not available (Lynis did not produce an index)
  warningCount    Int     @default(0)
  suggestionCount Int     @default(0)
  lynisVersion    String?

  // State of remediations at scan time (for historical detail)
  fail2banActive    Boolean @default(false)
  autoUpdatesActive Boolean @default(false)
  sshHardened       Boolean @default(false)
  firewallActive    Boolean @default(false)

  scannedAt DateTime @default(now())

  @@index([machineId, scannedAt])
}

// ===================== BOOTSTRAP TOKENS =====================
// Short-lived tokens (1h) to protect the download of the binary and the script
// during enrollment. Separate from Machine.enrollmentToken which serves the ECDSA handshake.

model BootstrapToken {
  id        String    @id @default(cuid())
  machineId String
  machine   Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  purpose   String    // 'install' (reserved: 'upgrade' for the future)
  tokenHash String    @unique   // SHA256 hex of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([machineId, purpose])
  @@index([expiresAt])
}

// ===================== APT PACKAGE CATALOG =====================
// Catalog of packages available in the Ubuntu repos.
// Ingested from archive.ubuntu.com/<dists>/<suite>/<component>/binary-<arch>/Packages.xz
// Full-text search via tsvector GIN index (searchVector, generated by an SQL trigger).

model AptPackage {
  id          String   @id @default(cuid())
  suite       String   // "noble", "jammy"
  component   String   // "main", "universe", "restricted", "multiverse"
  arch        String   // "amd64", "arm64", "all"
  name        String
  version     String
  description String   @db.Text
  section     String?
  size        Int?     // Installed-Size in KB

  searchVector Unsupported("tsvector")?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([suite, component, arch, name])
  @@index([name])
  @@index([suite])
}

// Metrics are no longer persisted. They live in an in-memory buffer (last ~30 min,
// services/metrics-buffer.ts) for the live UI view; long-term history is served by
// Prometheus/Grafana via the per-machine nexus_machine_* gauges. The Metric table was
// dropped (migration 20260707_drop_metric_table).

// ===================== EVENTS =====================

model MachineEvent {
  id        String   @id @default(cuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  type      String   // heartbeat, metrics, action, connection, disconnection, enrollment
  data      Json?
  timestamp DateTime @default(now())

  @@index([machineId, timestamp])
  @@index([type, timestamp])
}

// ===================== AUDIT =====================

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  resource   String      // machine, user, capability
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  machineId String?
  machine   Machine? @relation(fields: [machineId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([machineId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// ===================== ALERTS =====================

model AlertRule {
  id              String             @id @default(cuid())
  name            String
  description     String?
  enabled         Boolean            @default(true)
  severity        AlertSeverity      @default(WARNING)
  conditionType   AlertConditionType
  threshold       Float?             // Threshold (e.g. 90 for CPU > 90%, or 30 for CERT_EXPIRING in days)
  targetPattern   String?            // Filter (e.g. service name for SERVICE_FAILED, cron pattern)
  durationSeconds Int                @default(0)  // Duration before triggering (0 = immediate)
  machineIds      String[]           // Empty = all machines
  cooldownSeconds Int                @default(300) // Anti-spam (5 min by default)
  notifyEmail     Boolean            @default(false) // legacy, uses alert_email setting
  notifyWebhook   String?            // legacy, single HMAC-signed webhook
  channels        Json?              // [{type: "DISCORD"|"SLACK"|"TEAMS"|"EMAIL"|"WEBHOOK", config: {...}}]

  createdBy String?
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  states AlertState[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@index([conditionType])
}

model AlertState {
  id           String      @id @default(cuid())
  ruleId       String
  rule         AlertRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  machineId    String
  machine      Machine     @relation(fields: [machineId], references: [id], onDelete: Cascade)
  status       AlertStatus @default(FIRING)
  firedAt      DateTime    @default(now())
  resolvedAt   DateTime?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  lastNotified DateTime?
  details      Json?       // { value: 95.2, threshold: 90 }

  @@unique([ruleId, machineId, status])
  @@index([machineId])
  @@index([status])
  @@index([firedAt])
  // Composite for sorted active-alert listings (FIRING/ACKNOWLEDGED desc)
  @@index([status, firedAt(sort: Desc)])
}

// ===================== SETTINGS =====================

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ===================== TAGS =====================

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#6366f1")
  createdAt DateTime     @default(now())

  machines MachineTag[]
}

model MachineTag {
  id        String   @id @default(cuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([machineId, tagId])
  @@index([machineId])
  @@index([tagId])
}

// ===================== GROUPS =====================

model MachineGroup {
  id          String               @id @default(cuid())
  name        String               @unique
  description String?
  type        GroupType            @default(STATIC)
  filter      Json?                // For DYNAMIC: { tags: string[], status: string[] }
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  members MachineGroupMember[]
}

model MachineGroupMember {
  id        String       @id @default(cuid())
  groupId   String
  group     MachineGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  machineId String
  machine   Machine      @relation(fields: [machineId], references: [id], onDelete: Cascade)
  addedAt   DateTime     @default(now())

  @@unique([groupId, machineId])
  @@index([groupId])
  @@index([machineId])
}


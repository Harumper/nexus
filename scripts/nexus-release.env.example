# nexus-release.sh configuration — copy to ~/.config/nexus-release.env (never commit).
# Only GITLAB_TOKEN is strictly required; everything else has a default in the script.
#
# This tool drives a GitLab CI release pipeline. If you don't use GitLab CI, sign
# and publish manually instead — see RELEASING.md (no config file needed).

# GitLab instance whose CI builds the signed agent artifact.
GITLAB_URL=https://gitlab.example.com
# Project path, URL-encoded for the API (or the numeric project ID, e.g. 39).
PROJECT_ID=your-group%2Fnexus
# Same project path, plain, used only for UI links (manual tag deletion).
GITLAB_PROJECT_PATH=your-group/nexus

# Project access token scoped to write_api on THIS project only (reads artifacts +
# creates tags). Developer role — Maintainer if the 'v*' tags are protected.
GITLAB_TOKEN=

# Offline minisign private key that signs the release. NEVER leaves this host,
# never goes on an agent. Encrypted with a password at generation time.
RELEASE_KEY=$HOME/nexus-signing/nexus-release.key
# SSH key used to publish the signed artifact to the release host.
NEXUS_RELEASE_SSH_KEY=$HOME/.ssh/nexus-release

# Release host serving /release to agents, and the rsync/ssh user to reach it.
PROD_HOST=nexus.example.com
PROD_RELEASE_USER=nexus-release

# --- Optional overrides (defaults shown; uncomment to change) ---
# Git ref tagged by default — set to 'main' if that is your default branch.
#DEFAULT_REF=master
# Name of the CI job that produces the agent artifact (binary + sha256 + VERSION).
#RELEASE_JOB=release-build
# SSH host-key policy: 'accept-new' (TOFU on first contact) or 'yes' (refuse if unknown).
#SSH_STRICT=accept-new
# How long to wait for the CI artifact, and the polling interval (seconds).
#POLL_TIMEOUT=600
#POLL_INTERVAL=15
# Where the append-only release log is written.
#LOG_DIR=$HOME/.local/share/nexus-release

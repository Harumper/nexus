# ============================================
# Nexus - Configuration
# ============================================
# Copy this file to .env and edit the values:
#   cp .env.example .env
#   nano .env
#
# Generate random secrets:
#   openssl rand -hex 32

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=nexus
POSTGRES_PASSWORD=              # REQUIRED — openssl rand -hex 24
POSTGRES_DB=nexus
POSTGRES_PORT=26030

# ============================================
# Backend
# ============================================
BACKEND_PORT=26031
# DATABASE_URL is built automatically by docker-compose
# Only change it if PostgreSQL is external:
# DATABASE_URL=postgresql://nexus:PASSWORD@host:5432/nexus

# REQUIRED — openssl rand -hex 32
# MUST be distinct from ECDSA_MASTER_SECRET (never reuse the same secret
# for two different cryptographic purposes).
JWT_SECRET=

# REQUIRED — openssl rand -hex 32
# Encrypts agent private keys in the DB. MUST be distinct from JWT_SECRET.
# If lost, all agents must be re-enrolled
ECDSA_MASTER_SECRET=

# Enrollment token validity period (hours)
ENROLLMENT_TOKEN_EXPIRY_HOURS=24

# Delay before a machine is considered offline (seconds)
HEARTBEAT_TIMEOUT_SECONDS=90

# Public URL of the backend — used to generate the agent installation
# commands (add-machine wizard). Must be reachable from the target
# machines that will download the binary via /api/agents/download.
# If not set, the wizard shows a warning and no commands.
#
# RECOMMENDED: expose the backend behind Traefik with a domain + cert
# (mkcert locally via Technitium DNS, or Let's Encrypt) and point here to
# https://nexus.<your-domain>. The generated install command then converts
# automatically to wss:// (https->wss), so the agent speaks over a TLS-encrypted
# WebSocket. Combined with strict ECDSA pinning (server key required), you get
# double protection: TLS (transport + metadata confidentiality) and
# application-level signature (backend authenticity + isolation between projects).
#
# IMPORTANT (NEXUS-ENROLLMENT-001): wss:// (or an encrypted tunnel such as WireGuard)
# is REQUIRED for enrollment over any not-fully-trusted network.
# ECDSA pinning authenticates the server RESPONSE, NOT the enrollment request:
# the request carries the single-use token AND the agent's public key in cleartext
# at the application level. Over http://, an on-path attacker steals the token and
# substitutes their own public key (taking over the machine's identity on first
# contact). Only use http://ws:// in local dev on a trusted network, and the agent
# must then be installed with --insecure (it logs a WARNING on every
# boot). The post-enrollment WS payload is E2E encrypted (ECDSA + AES-GCM), but that
# does not cover the bootstrap.
AGENT_BACKEND_URL=https://nexus.example.com

# ============================================
# Authentication
# ============================================
# Mode: "local" (username/password), "keycloak" (SSO), "both"
AUTH_MODE=local

# Keycloak (required if AUTH_MODE=keycloak or both)
# KEYCLOAK_URL=https://auth.example.com
# KEYCLOAK_REALM=nexus
# KEYCLOAK_CLIENT_ID=nexus
# KEYCLOAK_CLIENT_SECRET=            # Optional, for confidential clients

# Mapping of Keycloak roles to Nexus
# KEYCLOAK_ROLE_ADMIN=nexus-admin
# KEYCLOAK_ROLE_OPERATOR=nexus-operator
# KEYCLOAK_ROLE_READONLY=nexus-readonly

# ============================================
# User privilege management (SSH keys / sudo)
# ============================================
# These actions (adding/removing SSH keys, toggling sudo, creating a user
# directly with sudo) create access that SURVIVES agent uninstallation
# and is no longer revocable by Nexus. They are therefore:
#   - DISABLED by default (this flag must be explicitly set to "true")
#   - restricted to the ADMIN role even once enabled
# Reading (listing users / keys) always stays available.
# Leave at false if you don't need to manage SSH keys/sudo from the UI.
ALLOW_USER_PRIVILEGE_MGMT=false

# ============================================
# Frontend
# ============================================
# TLS enabled by default — the UI is accessible at https://<host>:FRONTEND_TLS_PORT
# Self-signed cert generated automatically on first start (10 years).
# The browser will show a warning the first time → "Continue".
TLS_ENABLED=true
FRONTEND_TLS_PORT=26033

# The HTTP port (80) stays mapped for the 301 redirect to HTTPS, but in
# practice you access directly via https://<host>:26033
FRONTEND_PORT=26032

# External origin allowed by the frontend CSP (Content-Security-Policy):
# the domain of your SSO/OIDC (Keycloak) for connect-src + frame-src (silent-SSO
# iframe). Empty = self only (local auth). Examples:
# https://auth.example.com or a wildcard https://*.example.com. Substituted into
# the nginx config at startup (envsubst).
CSP_AUTH_ORIGIN=

# ⚠️ REQUIRED in real deployment (not optional) — just like JWT_SECRET /
# ECDSA_MASTER_SECRET / AGENT_BACKEND_URL.
# Serves TWO controls: HTTP CORS AND the Origin allow-list of the dashboard WebSocket
# (CSWSH, NEXUS-CONTROL-PLANE-001). If you leave it on a localhost while you
# access via a real domain, the dashboard rejects your own interface in a loop
# ("forbidden origin") — the backend WARNS about it at boot.
# FORMAT: FULL origin, byte-identical to the Origin sent by the browser —
#   WITHOUT trailing slash, WITHOUT explicit :443. E.g. behind Traefik:
#       FRONTEND_URL=https://nexus.example.com
#   Multiple domains: comma-separated (https://a.example,https://b.example).
FRONTEND_URL=https://localhost:26033

# TLS_CERT_DIR=./certs             # Mount existing certificates instead of the self-signed one

# ============================================
# Data retention
# ============================================
# 0 = no DB storage (Prometheus only), 7, 14, 30 (default)
# Also configurable via the API: PUT /api/settings/metrics_retention_days
# METRICS_RETENTION_DAYS=30

# ============================================
# Monitoring (Prometheus) — /metrics (NEXUS-WEB-AUTHZ-005)
# ============================================
# /metrics exposes per-machine telemetry (machine_id, hostname, CPU/mem/disk)
# for the WHOLE fleet. Two protections, ADDITIVE:
#   (B, default) network-scoping: does NOT route /metrics through the public entry
#       (the frontend nginx does not proxy /metrics) → internal scrape only.
#   (A, RECOMMENDED in real deployment) METRICS_TOKEN: if set, /metrics requires a
#       bearer (compared in constant time, fail-closed 401). Use it as soon as the
#       scraper crosses a not-strictly-trusted network (e.g. Prometheus on
#       another machine scraping host port 26031).
# Generate a secret: openssl rand -hex 32
# METRICS_TOKEN=
#
# prometheus.yml on the scraper side (with token):
#   - job_name: nexus
#     metrics_path: /metrics
#     authorization:
#       type: Bearer
#       credentials: "<the METRICS_TOKEN>"        # or: credentials_file: /etc/prometheus/nexus_metrics_token
#     static_configs:
#       - targets: ['nexus.example.com:26031']    # host port of the backend
# Without a token, remove the `authorization:` block.

# === Signed auto-upgrade — release PUBLIC key (Design A) ===
# Release minisign public key (contents of nexus-release.pub). If set, the
# backend EMBEDS it in the bootstrap command → /etc/nexus/release.pub is
# placed automatically on the agent at install AND at reenroll (otherwise the agent
# refuses auto-upgrade, fail-closed, and it must be placed manually).
# This is a PUBLIC key (no secret); the private key stays offline. Same
# value as the CI variable NEXUS_RELEASE_PUBKEY (signature verification at publish).
# FORMAT: a SINGLE line = the base64 line of nexus-release.pub (the one starting
# with RW…; the "untrusted comment:" line is optional, it is ignored).
# Generation: see OPERATOR-KEYS.md.
# NEXUS_RELEASE_PUBKEY=RWRo+LdKCdUi1/4rXyYU206e9dw8+TOxBGI/YC0cIrK56hlAdjpJBIyY

# ============================================
# Nexus - Configuration
# ============================================
# Copier ce fichier en .env et modifier les valeurs :
#   cp .env.example .env
#   nano .env
#
# Generer des secrets aleatoires :
#   openssl rand -hex 32

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=nexus
POSTGRES_PASSWORD=              # OBLIGATOIRE — openssl rand -hex 24
POSTGRES_DB=nexus
POSTGRES_PORT=26030

# ============================================
# Backend
# ============================================
BACKEND_PORT=26031
# DATABASE_URL est construit automatiquement par docker-compose
# Ne modifier que si PostgreSQL est externe :
# DATABASE_URL=postgresql://nexus:PASSWORD@host:5432/nexus

# OBLIGATOIRE — openssl rand -hex 32
# DOIT etre distinct de ECDSA_MASTER_SECRET (ne jamais reutiliser le meme secret
# pour deux usages cryptographiques differents).
JWT_SECRET=

# OBLIGATOIRE — openssl rand -hex 32
# Chiffre les cles privees des agents en DB. DOIT etre distinct de JWT_SECRET.
# Si perdu, tous les agents doivent etre re-enrolles
ECDSA_MASTER_SECRET=

# Duree de validite des tokens d'enrollment (heures)
ENROLLMENT_TOKEN_EXPIRY_HOURS=24

# Delai avant qu'une machine soit consideree offline (secondes)
HEARTBEAT_TIMEOUT_SECONDS=90

# URL publique du backend — utilisee pour generer les commandes d'installation
# de l'agent (wizard d'ajout de machine). Doit etre joignable depuis les
# machines cibles qui vont telecharger le binaire via /api/agents/download.
# Si non defini, le wizard affiche un avertissement et pas de commandes.
#
# RECOMMANDÉ : exposer le backend derrière Traefik avec un domaine + cert
# (mkcert en local via Technitium DNS, ou Let's Encrypt) et pointer ici en
# https://nexus.<ton-domaine>. La commande d'install générée convertit alors
# automatiquement en wss:// (https->wss), donc l'agent parle en WebSocket
# chiffré TLS. Combiné au pinning ECDSA strict (clé serveur obligatoire), on a
# une double protection : TLS (transport + confidentialité des métadonnées) et
# signature applicative (authenticité du backend + isolation entre projets).
#
# IMPORTANT (NEXUS-ENROLLMENT-001) : wss:// (ou un tunnel chiffré type WireGuard)
# est OBLIGATOIRE pour l'enrôlement sur tout réseau non pleinement de confiance.
# Le pinning ECDSA authentifie la RÉPONSE du serveur, PAS la requête d'enrôlement :
# celle-ci porte le token single-use ET la clé publique de l'agent en clair au
# niveau applicatif. En http://, un attaquant on-path vole le token et substitue
# sa propre clé publique (prise de contrôle de l'identité de la machine au premier
# contact). N'utilisez http://ws:// QUE en dev local sur réseau de confiance, et
# l'agent devra alors être installé avec --insecure (il loggue un WARNING à chaque
# boot). Le payload WS post-enrôlement est chiffré E2E (ECDSA + AES-GCM), mais cela
# ne couvre pas le bootstrap.
AGENT_BACKEND_URL=https://nexus.example.com

# ============================================
# Authentification
# ============================================
# Mode : "local" (username/password), "keycloak" (SSO), "both"
AUTH_MODE=local

# Keycloak (requis si AUTH_MODE=keycloak ou both)
# KEYCLOAK_URL=https://auth.example.com
# KEYCLOAK_REALM=nexus
# KEYCLOAK_CLIENT_ID=nexus
# KEYCLOAK_CLIENT_SECRET=            # Optionnel, pour les clients confidentiels

# Mapping des roles Keycloak vers Nexus
# KEYCLOAK_ROLE_ADMIN=nexus-admin
# KEYCLOAK_ROLE_OPERATOR=nexus-operator
# KEYCLOAK_ROLE_READONLY=nexus-readonly

# ============================================
# Gestion des privileges utilisateurs (clés SSH / sudo)
# ============================================
# Ces actions (ajout/suppression de clés SSH, bascule sudo, création d'un
# utilisateur directement sudo) créent un accès qui SURVIT à la désinstallation
# de l'agent et n'est plus révocable par Nexus. Elles sont donc :
#   - DESACTIVEES par défaut (ce flag doit valoir explicitement "true")
#   - réservées au rôle ADMIN même une fois activées
# La lecture (liste des utilisateurs / des clés) reste toujours disponible.
# Laisse à false si tu n'as pas besoin de gérer clés SSH/sudo depuis l'UI.
ALLOW_USER_PRIVILEGE_MGMT=false

# ============================================
# Frontend
# ============================================
# TLS activé par défaut — l'UI est accessible sur https://<host>:FRONTEND_TLS_PORT
# Cert auto-signé généré automatiquement au premier démarrage (10 ans).
# Le navigateur affichera un avertissement la première fois → "Continuer".
TLS_ENABLED=true
FRONTEND_TLS_PORT=26033

# Le port HTTP (80) reste mappé pour le redirect 301 vers HTTPS, mais en
# pratique tu accèdes directement à https://<host>:26033
FRONTEND_PORT=26032

# Origine externe autorisée par le CSP du frontend (Content-Security-Policy) :
# le domaine de ton SSO/OIDC (Keycloak) pour connect-src + frame-src (iframe
# silent-SSO). Vide = self uniquement (auth locale). Exemples :
# https://auth.example.com ou un wildcard https://*.example.com. Substitué dans
# la config nginx au démarrage (envsubst).
CSP_AUTH_ORIGIN=

# ⚠️ REQUIS en déploiement réel (pas optionnel) — au même titre que JWT_SECRET /
# ECDSA_MASTER_SECRET / AGENT_BACKEND_URL.
# Sert à DEUX contrôles : le CORS HTTP ET l'allow-list d'Origin du WebSocket dashboard
# (CSWSH, NEXUS-CONTROL-PLANE-001). Si tu la laisses sur un localhost alors que tu
# accèdes via un vrai domaine, le dashboard rejette ta propre interface en boucle
# ("forbidden origin") — le backend l'AVERTIT au boot.
# FORMAT : origine COMPLÈTE, byte-identique à l'Origin envoyé par le navigateur —
#   SANS slash final, SANS :443 explicite. Ex. derrière Traefik :
#       FRONTEND_URL=https://nexus.exemple.com
#   Plusieurs domaines : séparés par virgule (https://a.exemple,https://b.exemple).
FRONTEND_URL=https://localhost:26033

# TLS_CERT_DIR=./certs             # Monter des certificats existants à la place du self-signed

# ============================================
# Retention des donnees
# ============================================
# 0 = pas de stockage en DB (Prometheus seul), 7, 14, 30 (defaut)
# Configurable aussi via l'API : PUT /api/settings/metrics_retention_days
# METRICS_RETENTION_DAYS=30

# ============================================
# Monitoring (Prometheus) — /metrics (NEXUS-WEB-AUTHZ-005)
# ============================================
# /metrics expose la télémétrie par machine (machine_id, hostname, CPU/mém/disque)
# de TOUTE la flotte. Deux protections, ADDITIVES :
#   (B, défaut) network-scoping : ne route PAS /metrics via l'entrée publique
#       (le nginx du frontend ne proxifie pas /metrics) → scrape interne seulement.
#   (A, RECOMMANDÉ en déploiement réel) METRICS_TOKEN : si défini, /metrics exige un
#       bearer (comparé en temps constant, fail-closed 401). À utiliser dès que le
#       scraper traverse un réseau non strictement de confiance (ex. Prometheus sur
#       une autre machine scrapant le port hôte 26031).
# Génère un secret : openssl rand -hex 32
# METRICS_TOKEN=
#
# prometheus.yml côté scraper (avec token) :
#   - job_name: nexus
#     metrics_path: /metrics
#     authorization:
#       type: Bearer
#       credentials: "<le METRICS_TOKEN>"        # ou: credentials_file: /etc/prometheus/nexus_metrics_token
#     static_configs:
#       - targets: ['nexus.example.com:26031']    # port hôte du backend
# Sans token, retire le bloc `authorization:`.

# === Auto-upgrade signé — clé PUBLIQUE de release (Design A) ===
# Clé publique minisign de release (contenu de nexus-release.pub). Si définie, le
# backend l'EMBARQUE dans la commande de bootstrap → /etc/nexus/release.pub est
# posée automatiquement sur l'agent à l'install ET au reenroll (sinon, l'agent
# refuse l'auto-upgrade, fail-closed, et il faut la déposer à la main).
# C'est une clé PUBLIQUE (aucun secret) ; la clé privée reste hors-ligne. Même
# valeur que la variable CI NEXUS_RELEASE_PUBKEY (vérif de la signature au publish).
# FORMAT : une SEULE ligne = la ligne base64 de nexus-release.pub (celle qui commence
# par RW… ; la ligne "untrusted comment:" est facultative, elle est ignorée).
# Génération : voir OPERATOR-KEYS.md.
# NEXUS_RELEASE_PUBKEY=RWRo+LdKCdUi1/4rXyYU206e9dw8+TOxBGI/YC0cIrK56hlAdjpJBIyY

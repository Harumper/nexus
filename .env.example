# ============================================
# Nexus - Configuration
# ============================================
# Copier ce fichier en .env et modifier les valeurs

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=nexus
POSTGRES_PORT=26030

# Backend
BACKEND_PORT=26031
DATABASE_URL=postgresql://nexus:change_me_in_production@postgres:5432/nexus
JWT_SECRET=change_me_to_random_64_chars_minimum
ECDSA_MASTER_SECRET=change_me_to_random_64_chars_minimum
ENROLLMENT_TOKEN_EXPIRY_HOURS=24
HEARTBEAT_TIMEOUT_SECONDS=90
METRICS_RETENTION_DAYS=30

# ============================================
# Authentification
# ============================================
# Mode: "local" (username/password), "keycloak" (SSO uniquement), "both" (les deux)
AUTH_MODE=local

# Keycloak (requis si AUTH_MODE=keycloak ou both)
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_REALM=nexus
KEYCLOAK_CLIENT_ID=nexus
# KEYCLOAK_CLIENT_SECRET=          # Optionnel, pour les clients confidentiels

# Mapping des rôles Keycloak (realm roles) vers Nexus
KEYCLOAK_ROLE_ADMIN=nexus-admin
KEYCLOAK_ROLE_OPERATOR=nexus-operator
KEYCLOAK_ROLE_READONLY=nexus-readonly

# Frontend
FRONTEND_PORT=26032
FRONTEND_URL=http://localhost:26032

# Agent (pour le test local)
AGENT_MACHINE_ID=
AGENT_ENROLLMENT_TOKEN=
AGENT_SERVER_PUBLIC_KEY=
NEXUS_SERVER_URL=ws://backend:3000/ws/agent
HEARTBEAT_INTERVAL=30
METRICS_INTERVAL=60
